  {
  "id": "15",
  "titolo": "Angolo corretto di un vettore con offset",
    "output": "theta",
  "equazione_testo": "theta = phi + atan(x2/x1) (dove phi è in radianti)",
  "funzione": "phi + atan(x2/x1)",

  "msg": "Per maggiore chiarezza si specifica che x1 rappresenta la componente orizzontale di un vettore, x2 la componente verticale e phi rappresenta un offset angolare o una correzione di allineamento.",

  "nominali": {
    "x1": 3,
    "x2": 4,
    "phi_deg": 10
  },

  "sens": {
    "cx1": "-x2/(x1^2 + x2^2)",
    "cx2": "x1/(x1^2 + x2^2)",
    "cphi": "1",

    "crx1": "-(x1*x2)/((x1^2 + x2^2)*(phi + atan(x2/x1)))",
    "crx2": "(x1*x2)/((x1^2 + x2^2)*(phi + atan(x2/x1)))",
    "crphi": "phi/(phi + atan(x2/x1))"
  },

  "unc": {
    "abs_wcu": [
      { "Ux1": 0.05, "Ux2": 0.05, "Uphi_deg": 0.2 }
    ],
    "abs_std": [
      { "ux1": 0.02, "ux2": 0.02, "uphi_deg": 0.1 }
    ],
    "rel_wcu": [
      { "Urx1": 0.01, "Urx2": 0.01, "Uphi_deg": 0.2 }
    ],
    "rel_std": [
      { "urx1": 0.005, "urx2": 0.005, "uphi_deg": 0.1 }
    ]
  }
}
