[
  {
    "id": "1",
    "titolo": "Espressione di una sinusoide",
    "output": "theta",
    "equazione_testo": "theta = cos(2*pi*x1*x2 + phi) (dove phi è in radianti)",
    "funzione": "cos(2*pi*x1*x2 + phi)",
    "msg": "Per maggiore chiarezza si specifica che la variabile x1 rappresenta la frequenza del segnale, mentre x2 rappresenta il tempo.",

    "nominali": {
      "x1": 2,
      "x2": 1,
      "phi_deg": 21
    },

    "sens": {
      "cx1": "-2*pi*x2*sin(2*pi*x1*x2 + phi)",
      "cx2": "-2*pi*x1*sin(2*pi*x1*x2 + phi)",
      "cphi": "-sin(2*pi*x1*x2 + phi)",

      "crx1": "-(2*x1*x2*pi*sin(phi + 2*pi*x1*x2))/cos(phi + 2*pi*x1*x2)",
      "crx2": "-(2*x1*x2*pi*sin(phi + 2*pi*x1*x2))/cos(phi + 2*pi*x1*x2)",
      "crphi": "-(phi*sin(phi + 2*pi*x1*x2))/cos(phi + 2*pi*x1*x2)"
    },

    "unc": {
      "abs_wcu": [
        { "Ux1": 0.02, "Ux2": 0.02, "Uphi_deg": 0.63 }
      ],
      "abs_std": [
        { "ux1": 0.012, "ux2": 0.012, "uphi_deg": 0.4 }
      ],
      "rel_wcu": [
        { "Urx1": 0.01, "Urx2": 0.02, "Uphi_deg": 0.63 }
      ],
      "rel_std": [
        { "urx1": 0.006, "urx2": 0.012, "uphi_deg": 0.4 }
      ]
  }
  },

{
  "id": "2",
  "titolo": "Distanza ricavata da velocità, tempo e angolo",
  "output": "theta",
  "equazione_testo": "theta = x1*x2 / tan(phi) (dove phi è in radianti)",
  "funzione": "x1*x2 / tan(phi)",

  "nominali": {
    "x1": 100,
    "x2": 25,
    "phi_deg": 38
  },

  "sens": {
    "cx1": "x2/tan(phi)",
    "cx2": "x1/tan(phi)",
    "cphi": "-x1*x2/(sin(phi)^2)",

    "crx1": "1",
    "crx2": "1",
    "crphi": "-phi/(sin(phi)*cos(phi))"
  },

  "unc": {
    "abs_wcu": [
      { "Ux1": 1.0, "Ux2": 0.2, "Uphi_deg": 0.5 }
    ],
    "abs_std": [
      { "ux1": 0.5, "ux2": 0.01, "uphi_deg": 0.1 }
    ],
    "rel_wcu": [
      { "Urx1": 0.01, "Urx2": 0.008, "Uphi_deg": 0.5 }
    ],
    "rel_std": [
      { "urx1": 0.005, "urx2": 0.0004, "uphi_deg": 0.1 }
    ]
  }
},
  {
  "id": "3",
  "titolo": "Lato di un triangolo ricavato da area, lato e angolo",
    "output": "theta",
  "equazione_testo": "theta = 2*x2 / (x1*sin(phi)) (dove phi è in radianti)",
  "funzione": "2*x2/(x1*sin(phi))",

  "nominali": {
    "x1": 10,
    "x2": 25,
    "phi_deg": 32
  },

  "sens": {
    "cx1": "-(2*x2)/(x1^2*sin(phi))",
    "cx2": "2/(x1*sin(phi))",
    "cphi": "(2*x2*cos(phi))/(x1*(cos(phi)^2 - 1))",

    "crx1": "-1",
    "crx2": "1",
    "crphi": "-(phi*cos(phi))/sin(phi)"
  },

  "unc": {
    "abs_wcu": [
      { "Ua": 0.01, "Us": 0.02, "Uphi_deg": 0.2 }
    ],
    "abs_std": [
      { "ua": 0.06, "us": 0.29, "uphi_deg": 0.12 }
    ],
    "rel_wcu": [
      { "Ura": 0.01, "Urs": 0.02, "Uphi_deg": 0.2 }
    ],
    "rel_std": [
      { "ura": 0.006, "urs": 0.012, "uphi_deg": 0.12 }
    ]
  }
},
  {
  "id": "4",
  "titolo": "Prodotto modulato da arctan dell’angolo",
    "output": "theta",
  "equazione_testo": "theta = x1*x2*atan(phi) (dove phi è in radianti)",
  "funzione": "x1*x2*atan(phi)",

  "nominali": {
    "x1": 12,
    "x2": 4,
    "phi_deg": 28
  },

  "sens": {
    "cx1": "x2*atan(phi)",
    "cx2": "x1*atan(phi)",
    "cphi": "(x1*x2)/(1 + phi^2)",

    "crx1": "1",
    "crx2": "1",
    "crphi": "phi/(atan(phi)*(phi^2 + 1))"
  },

  "unc": {
    "abs_wcu": [
      { "Ux1": 0.2, "Ux2": 0.1, "Uphi_deg": 0.5 }
    ],
    "abs_std": [
      { "ux1": 0.12, "ux2": 0.05, "uphi_deg": 0.3 }
    ],
    "rel_wcu": [
      { "Urx1": 0.015, "Urx2": 0.02, "Uphi_deg": 0.5 }
    ],
    "rel_std": [
      { "urx1": 0.008, "urx2": 0.01, "uphi_deg": 0.3 }
    ]
  }
},
  {
  "id": "5",
  "titolo": "Calcolo del lato di un triangolo tramite teorema del coseno",
    "output": "theta",
  "equazione_testo": "theta = sqrt(x1^2 + x2^2 - 2*x1*x2*cos(phi)) (dove phi è in radianti)",
  "funzione": "sqrt(x1^2 + x2^2 - 2*x1*x2*cos(phi))",

  "msg": "Per maggiore chiarezza si specifica che le variabili x1 e x2 rappresentano due lati noti di un triangolo, mentre phi rappresenta l’angolo compreso tra essi.",

  "nominali": {
    "x1": 8,
    "x2": 6,
    "phi_deg": 45
  },

  "sens": {
    "cx1": "(x1 - x2*cos(phi))/(x1^2 - 2*cos(phi)*x1*x2 + x2^2)^(1/2)",
    "cx2": "(x2 - x1*cos(phi))/(x1^2 - 2*cos(phi)*x1*x2 + x2^2)^(1/2)",
    "cphi": "(x1*x2*sin(phi))/(x1^2 - 2*cos(phi)*x1*x2 + x2^2)^(1/2)",

    "crx1": "(x1*(x1 - x2*cos(phi)))/(x1^2 - 2*cos(phi)*x1*x2 + x2^2)",
    "crx2": "(x2*(x2 - x1*cos(phi)))/(x1^2 - 2*cos(phi)*x1*x2 + x2^2)",
    "crphi": "(phi*x1*x2*sin(phi))/(x1^2 - 2*cos(phi)*x1*x2 + x2^2)"
  },

  "unc": {
    "abs_wcu": [
      { "Ux1": 0.1, "Ux2": 0.1, "Uphi_deg": 0.5 }
    ],
    "abs_std": [
      { "ux1": 0.05, "ux2": 0.05, "uphi_deg": 0.3 }
    ],
    "rel_wcu": [
      { "Urx1": 0.02, "Urx2": 0.02, "Uphi_deg": 0.5 }
    ],
    "rel_std": [
      { "urx1": 0.01, "urx2": 0.01, "uphi_deg": 0.3 }
    ]
  }
},
  {
  "id": "6",
  "titolo": "Area di un triangolo da due lati e angolo compreso",
    "output": "theta",
  "equazione_testo": "theta = (1/2)*x1*x2*sin(phi) (dove phi è in radianti)",
  "funzione": "(1/2)*x1*x2*sin(phi)",

  "msg": "Per maggiore chiarezza si specifica che le variabili x1 e x2 rappresentano due lati noti di un triangolo, mentre phi rappresenta l’angolo compreso tra essi.",

  "nominali": {
    "x1": 12,
    "x2": 9,
    "phi_deg": 40
  },

  "sens": {
    "cx1": "(x2*sin(phi))/2",
    "cx2": "(x1*sin(phi))/2",
    "cphi": "(x1*x2*cos(phi))/2",

    "crx1": "1",
    "crx2": "1",
    "crphi": "(phi*cos(phi))/sin(phi)"
  },

  "unc": {
    "abs_wcu": [
      { "Ux1": 0.2, "Ux2": 0.2, "Uphi_deg": 0.5 }
    ],
    "abs_std": [
      { "ux1": 0.1, "ux2": 0.1, "uphi_deg": 0.3 }
    ],
    "rel_wcu": [
      { "Urx1": 0.02, "Urx2": 0.02, "Uphi_deg": 0.5 }
    ],
    "rel_std": [
      { "urx1": 0.01, "urx2": 0.01, "uphi_deg": 0.3 }
    ]
  }
},
  {
  "id": "7",
  "titolo": "Distanza tramite triangolazione",
    "output": "theta",
  "equazione_testo": "theta = (x1*x2)/(x2 - x1*cos(phi)) (dove phi è in radianti)",
  "funzione": "(x1*x2)/(x2 - x1*cos(phi))",

  "msg": "Per maggiore chiarezza si specifica che x1 e x2 rappresentano due distanze misurate da due punti di osservazione, mentre phi rappresenta l’angolo tra le due direzioni di misura.",

  "nominali": {
    "x1": 20,
    "x2": 35,
    "phi_deg": 40
  },

  "sens": {
    "cx1": "x2^2/(x2 - x1*cos(phi))^2",
    "cx2": "-(x1^2*cos(phi))/(x2 - x1*cos(phi))^2",
    "cphi": "-(x1^2*x2*sin(phi))/(x2 - x1*cos(phi))^2",

    "crx1": "x2/(x2 - x1*cos(phi))",
    "crx2": "-(x1*cos(phi))/(x2 - x1*cos(phi))",
    "crphi": "-(phi*x1*sin(phi))/(x2 - x1*cos(phi))"
  },

  "unc": {
    "abs_wcu": [
      { "Ux1": 0.3, "Ux2": 0.3, "Uphi_deg": 0.4 }
    ],
    "abs_std": [
      { "ux1": 0.15, "ux2": 0.15, "uphi_deg": 0.2 }
    ],
    "rel_wcu": [
      { "Urx1": 0.02, "Urx2": 0.02, "Uphi_deg": 0.4 }
    ],
    "rel_std": [
      { "urx1": 0.01, "urx2": 0.01, "uphi_deg": 0.2 }
    ]
  }
},
  {
  "id": "8",
  "titolo": "Modulo della somma di due vettori",
    "output": "theta",
  "equazione_testo": "theta = sqrt(x1^2 + x2^2 + 2*x1*x2*cos(phi)) (dove phi è in radianti)",
  "funzione": "sqrt(x1^2 + x2^2 + 2*x1*x2*cos(phi))",

  "msg": "Per maggiore chiarezza si specifica che x1 e x2 rappresentano i moduli di due vettori, mentre phi rappresenta l’angolo tra i due vettori.",

