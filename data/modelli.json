  {
  "id": "11",
  "titolo": "Combinazione lineare di tan(phi) e cot(phi)",
    "output": "theta",
  "equazione_testo": "theta = x1*tan(phi) + x2*cot(phi) (dove phi è in radianti)",
  "funzione": "x1*tan(phi) + x2*cot(phi)",

  "nominali": {
    "x1": 5,
    "x2": 3,
    "phi_deg": 40
  },

  "sens": {
    "cx1": "tan(phi)",
    "cx2": "cot(phi)",
    "cphi": "x1*(tan(phi)^2 + 1) - x2*(1/tan(phi)^2 + 1)",

    "crx1": "(x1*tan(phi)^2)/(x1*tan(phi)^2 + x2)",
    "crx2": "x2/(x1*tan(phi)^2 + x2)",
    "crphi": "-(phi*(tan(phi)^2 + 1)*(x2 - x1*tan(phi)^2))/(tan(phi)*(x1*tan(phi)^2 + x2))"
  },

  "unc": {
    "abs_wcu": [
      { "Ux1": 0.1, "Ux2": 0.1, "Uphi_deg": 0.4 }
    ],
    "abs_std": [
      { "ux1": 0.05, "ux2": 0.05, "uphi_deg": 0.2 }
    ],
    "rel_wcu": [
      { "Urx1": 0.02, "Urx2": 0.02, "Uphi_deg": 0.4 }
    ],
    "rel_std": [
      { "urx1": 0.01, "urx2": 0.01, "uphi_deg": 0.2 }
    ]
  }
},
