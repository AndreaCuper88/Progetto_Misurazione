  },

  "sens": {
    "cx1": "(x1 + x2*cos(phi))/(x1^2 + 2*cos(phi)*x1*x2 + x2^2)^(1/2)",
    "cx2": "(x2 + x1*cos(phi))/(x1^2 + 2*cos(phi)*x1*x2 + x2^2)^(1/2)",
    "cphi": "-(x1*x2*sin(phi))/(x1^2 + 2*cos(phi)*x1*x2 + x2^2)^(1/2)",

    "crx1": "(x1*(x1 + x2*cos(phi)))/(x1^2 + 2*cos(phi)*x1*x2 + x2^2)",
    "crx2": "(x2*(x2 + x1*cos(phi)))/(x1^2 + 2*cos(phi)*x1*x2 + x2^2)",
    "crphi": "-(phi*x1*x2*sin(phi))/(x1^2 + 2*cos(phi)*x1*x2 + x2^2)"
  },

  "unc": {
    "abs_wcu": [
      { "Ux1": 0.2, "Ux2": 0.2, "Uphi_deg": 0.4 }
    ],
    "abs_std": [
      { "ux1": 0.1, "ux2": 0.1, "uphi_deg": 0.2 }
    ],
    "rel_wcu": [
      { "Urx1": 0.02, "Urx2": 0.02, "Uphi_deg": 0.4 }
    ],
    "rel_std": [
      { "urx1": 0.01, "urx2": 0.01, "uphi_deg": 0.2 }
    ]
  }
},
  {
  "id": "9",
  "titolo": "Altezza corretta con inclinazione",
    "output": "theta",
  "equazione_testo": "theta = x1*tan(phi) + x2 (dove phi è in radianti)",
  "funzione": "x1*tan(phi) + x2",

  "msg": "Per maggiore chiarezza si specifica che la variabile x1 rappresenta la distanza orizzontale dall’oggetto, x2 rappresenta la quota iniziale (ad esempio l’altezza dello strumento) e phi rappresenta l’angolo di elevazione espresso in radianti.",

  "nominali": {
    "x1": 20,
    "x2": 1.5,
    "phi_deg": 35
  },

  "sens": {
    "cx1": "tan(phi)",
    "cx2": "1",
    "cphi": "x1*(tan(phi)^2 + 1)",

    "crx1": "(x1*tan(phi))/(x2 + x1*tan(phi))",
    "crx2": "x2/(x2 + x1*tan(phi))",
    "crphi": "(phi*x1*(tan(phi)^2 + 1))/(x2 + x1*tan(phi))"
  },

  "unc": {
    "abs_wcu": [
      { "Ux1": 0.2, "Ux2": 0.02, "Uphi_deg": 0.4 }
    ],
    "abs_std": [
      { "ux1": 0.1, "ux2": 0.01, "uphi_deg": 0.2 }
    ],
    "rel_wcu": [
      { "Urx1": 0.01, "Urx2": 0.02, "Uphi_deg": 0.4 }
    ],
    "rel_std": [
      { "urx1": 0.005, "urx2": 0.01, "uphi_deg": 0.2 }
    ]
  }
},
  {
  "id": "10",
