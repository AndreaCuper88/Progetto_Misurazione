    "crx1": "x1^2/(x1^2 + tan(phi)*x2^2)",
    "crx2": "(x2^2*tan(phi))/(x1^2 + tan(phi)*x2^2)",
    "crphi": "(phi*x2^2*(tan(phi)^2 + 1))/(2*(x1^2 + tan(phi)*x2^2))"
